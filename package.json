{
  "name": "portfolio-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "node scripts/build-static-export.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run --project a11y",
    "test:unit": "vitest run --project unit",
    "validate:content": "node ./scripts/validate-json-ci.mjs",
    "test:sanity": "node --env-file=.env.local scripts/test-sanity.mjs",
    "upload:videos": "node --env-file=.env.local scripts/upload-videos-to-sanity.mjs",
    "seed:sanity": "node --env-file=.env.local scripts/seed-sanity-from-mock.mjs",
    "migrate:hero-ctas": "node --env-file=.env.local scripts/migrate-hero-cta-to-ctas.mjs",
    "cleanup:sanity-pages": "node --env-file=.env.local scripts/cleanup-sanity-duplicate-pages.mjs",
    "sanity:dev": "node --env-file=.env.local node_modules/.bin/sanity dev",
    "sanity:dev:polling": "CHOKIDAR_USEPOLLING=1 node --env-file=.env.local node_modules/.bin/sanity dev",
    "sanity:deploy": "sanity deploy"
  },
  "dependencies": {
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/vision": "^5.22.0",
    "embla-carousel-react": "^8.0.0",
    "next": "^16.2.0",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.12.4",
    "sanity": "^5.22.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ajv": "^8.18.0",
    "axe-core": "^4.11.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "cms",
    "sanity",
    "content-driven",
    "portfolio",
    "starter-template",
    "tailwind"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.2",
    "@tailwindcss/oxide-linux-arm64-gnu": "4.2.1",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.1",
    "lightningcss-linux-arm64-gnu": "1.31.1",
    "lightningcss-linux-x64-gnu": "1.31.1"
  }
}
